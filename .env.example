# All VITE_* values are exposed to browser JavaScript.
# Do not put secrets, client secrets, passwords, private keys, or real e2e tokens here.

# normal auth mode: msal
# Playwright-only auth mode: e2e-token
VITE_AUTH_MODE=msal

# Existing ASP.NET Core API base URL.
VITE_API_BASE_URL=

# Azure AD/MSAL browser configuration.
VITE_AAD_CLIENT_ID=
VITE_AAD_AUTHORITY=
VITE_AAD_REDIRECT_URI=
VITE_AAD_API_SCOPE=

# Application Insights browser-visible configuration.
# Use either the existing instrumentation key or a connection string if the resource is updated.
VITE_APP_INSIGHTS_KEY=
VITE_APP_INSIGHTS_CONNECTION_STRING=

# Build/version display value.
VITE_EWRS_VERSION=

# E2E only. Never commit a real token.
VITE_E2E_TOKEN=
